{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"./hooks/session-start-openspec.js\"",
            "statusMessage": "Loading OpenSpec context...",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"./hooks/post-java-check.js\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
